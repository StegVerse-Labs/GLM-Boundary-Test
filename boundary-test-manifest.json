  "done_criteria": [
    "REVIEW_ONLY outcome is documented",
    "positive fixture exists",
    "invalid-control fixture exists",
    "local runners exist",
    "CI workflow exists",
    "reviewer handoff exists",
    "release readiness checklist exists",
    "no GLM conformance or interoperability claim is made"
  ]
